{
  "name": "book-manager-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "REST API para conectar Book Manager con Oracle Cloud Database.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "check": "node --check src/server.js && node --check src/scripts/checkDb.js",
    "check:db": "node src/scripts/checkDb.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "morgan": "^1.10.0",
    "nodemailer": "^8.0.7",
    "oracledb": "^6.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
