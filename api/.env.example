PORT=3000
NODE_ENV=development

# Oracle Cloud Database
# Ejemplo easy connect: host:1521/service_name
ORACLE_USER=BOOK_MANAGER
ORACLE_PASSWORD=change_me
ORACLE_CONNECT_STRING=host:1521/service_name
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=8
ORACLE_POOL_INCREMENT=1

# Opcional si usas wallet de Autonomous Database.
# TNS_ADMIN=/ruta/a/wallet
# ORACLE_WALLET_PASSWORD=clave_del_wallet

# SMTP para enviar codigos de verificacion por correo.
# Ejemplo Gmail: host smtp.gmail.com, puerto 587, SMTP_SECURE=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=correo@example.com
SMTP_PASSWORD=change_me
SMTP_FROM="Book Manager <correo@example.com>"
